{
    "tasks": [
        {
            "label": "Build Gurotopia",
            "type": "cppbuild",
            "command": "c:/msys64/ucrt64.exe",
            "args": [
                "-c",
                "cd \"$(pwd)\" && make -j$(nproc)"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Clean Gurotopia",
            "type": "cppbuild",
            "command": "c:/msys64/ucrt64.exe",
            "args": [
                "-c",
                "cd \"$(pwd)\" && make clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        }
    ]
}